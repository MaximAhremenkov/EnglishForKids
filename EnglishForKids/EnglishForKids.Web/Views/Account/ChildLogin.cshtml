@model EnglishForKids.Web.ViewModels.ChildLoginViewModel

@{
    ViewData["Title"] = "Вход для детей";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="question-area p-5 text-center">
                <div class="topic-icon mx-auto mb-4">
                    👶
                </div>

                <h2 class="mb-4">Привет! Войди в свой аккаунт</h2>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger">
                        @Html.ValidationSummary(false)
                    </div>
                }

                <form method="post">
                    <div class="mb-4">
                        <label class="form-label">Email мамы или папы</label>
                        <input type="email" name="ParentEmail" class="form-control form-control-lg"
                               placeholder=" mama@example.com" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Твой секретный PIN-код</label>
                        <input type="text" name="PinCode" class="form-control form-control-lg text-center"
                               placeholder="🔢 1234" maxlength="4" pattern="[0-9]{4}"
                               inputmode="numeric" autocomplete="off" required>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100 mb-3">
                        Войти в игру 🎮
                    </button>
                </form>

                <div class="mt-4">
                    <img src="https://via.placeholder.com/150/4CAF50/ffffff?text=🐶" alt="Маскот" class="img-fluid" style="max-width: 150px;">
                </div>

                <div class="mt-3">
                    <p>Не знаешь PIN-код? Спроси у родителей!</p>
                    <a href="/Account/Login">👨‍👩‍👧 Вход для родителей</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelector('input[name="PinCode"]').focus();
    });
</script>