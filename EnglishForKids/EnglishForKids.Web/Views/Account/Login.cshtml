@{
    ViewData["Title"] = "Вход для родителей";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="question-area">
                <h2 class="text-center mb-4">🔐 Вход для родителей</h2>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control form-control-lg" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Пароль</label>
                        <input type="password" name="password" class="form-control form-control-lg" required>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">Войти</button>
                </form>

                <div class="text-center mt-3">
                    <a href="/Account/Register">Нет аккаунта? Зарегистрироваться</a>
                    <br>
                    <a href="/Account/ChildLogin" class="btn btn-warning mt-3">👶 Вход для детей</a>
                </div>
            </div>
        </div>
    </div>
</div>