@{
    ViewData["Title"] = "Регистрация родителя";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="question-area">
                <h2 class="text-center mb-4">📝 Регистрация родителя</h2>

                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Ваше имя</label>
                        <input type="text" name="fullName" class="form-control form-control-lg" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control form-control-lg" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Пароль</label>
                        <input type="password" name="password" class="form-control form-control-lg" required>
                        <small class="text-muted">Минимум 4 символа</small>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100">Зарегистрироваться</button>
                </form>

                <div class="text-center mt-3">
                    <a href="/Account/Login">Уже есть аккаунт? Войти</a>
                </div>
            </div>
        </div>
    </div>
</div>