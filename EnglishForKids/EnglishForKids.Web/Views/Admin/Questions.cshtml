@using EnglishForKids.Data.Enums
@model IEnumerable<EnglishForKids.Data.Entities.Question>
@{
    ViewData["Title"] = "Управление вопросами";
    Layout = "_LayoutAdmin";
    var topics = ViewBag.Topics as List<EnglishForKids.Data.Entities.Topic>;
    var selectedTopicId = ViewBag.SelectedTopicId;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>❓ Управление вопросами</h1>
        <a href="/Admin/CreateQuestion" class="btn btn-success btn-lg">➕ Создать вопрос</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Фильтр по теме -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Фильтр по теме</label>
                    <select name="topicId" class="form-select" onchange="this.form.submit()">
                        <option value="">Все темы</option>
                        @foreach (var topic in topics)
                        {
                            <option value="@topic.Id" selected="@(selectedTopicId == topic.Id)">@topic.Title</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">Применить</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Тема</th>
                        <th>Тип</th>
                        <th>Вопрос</th>
                        <th>Сложность</th>
                        <th>Варианты</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in Model)
                    {
                        <tr>
                            <td>@q.Id</td>
                            <td>@q.Topic?.Title</td>
                            <td>
                                @switch (q.QuestionType)
                                {
                                    case QuestionType.TrueFalse:<span>✅ Правда/Ложь</span> break;
                                    case QuestionType.MultipleChoice: <span>❓ Выбор ответа</span> break;
                                    case QuestionType.Spelling: <span>📝 Вставь букву</span> break;
                                    case QuestionType.Translation: <span>🔄 Перевод</span> break;
                                    case QuestionType.SentenceBuilder: <span>🧩 Составь предложение</span> break;
                                    default: <span>@q.QuestionType</span>break;
                            }
                            </td>
                            <td>@q.Text</td>
                            <td>
                                @switch (q.Difficulty)
                                {
                                    case DifficultyLevel.Easy:<span class="badge bg-success">Легкий</span> break;
                                    case DifficultyLevel.Medium: <span class="badge bg-warning">Средний</span> break;
                                    case DifficultyLevel.Hard: <span class="badge bg-danger">Сложный</span> break;
                                    default: <span class="badge bg-secondary">@q.Difficulty</span>break;
                            }
                            </td>
                            <td>
                                @if (q.Options != null && q.Options.Any())
                                {
                                    <span class="badge bg-info">@q.Options.Count вар.</span>
                                }
                                else if (q.QuestionType == QuestionType.MultipleChoice || q.QuestionType == QuestionType.Translation)
                                {
                                    <span class="badge bg-danger">Нет вариантов</span>
                                }
                            </td>
                            <td>
                                <a href="/Admin/EditQuestion/@q.Id" class="btn btn-sm btn-primary">✏️ Ред.</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>