@model EnglishForKids.Web.ViewModels.GameViewModel
@{
    ViewData["Title"] = "Выбери правильный ответ";
}

<div class="container mt-3">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>@Model.TopicTitle</h2>
                <div>
                    <span class="badge bg-warning fs-4" id="scoreDisplay">⭐ @Model.Score</span>
                    <span class="badge bg-info fs-4" id="questionCounter">@(Model.CurrentQuestionIndex+1)/@Model.TotalQuestions</span>
                </div>
            </div>

            <div class="progress mb-4">
                <div class="progress-bar" id="progressBar" style="width: @((Model.CurrentQuestionIndex) * 100.0 / Model.TotalQuestions)%"></div>
            </div>
        </div>
    </div>

    <div id="game-container" data-questionid="@Model.CurrentQuestion.Id">
        <div class="question-area text-center">
            <h2 class="display-5 mb-4" id="questionText">@Model.CurrentQuestion.Text</h2>
        </div>

        <div class="row mt-4" id="optionsContainer">
            @if (Model.CurrentQuestion.Options != null)
            {
                var options = Model.CurrentQuestion.Options.OrderBy(o => o.Order).ToList();
                for (int i = 0; i < options.Count; i++)
                {
                    <div class="col-md-6 mb-3">
                        <button class="option-btn btn btn-primary btn-lg w-100"
                                data-option-id="@options[i].Id"
                                data-is-correct="@options[i].IsCorrect.ToString().ToLower()">
                            <span class="option-letter">@((char)('A' + i))</span>
                            <span class="option-text">@options[i].Text</span>
                        </button>
                    </div>
                }
            }
        </div>

        <div id="feedback" class="text-center mt-4" style="display: none;">
            <h2 id="feedbackMessage"></h2>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Элементы
        const container = document.getElementById('game-container');
        const questionText = document.getElementById('questionText');
        const optionsContainer = document.getElementById('optionsContainer');
        const feedback = document.getElementById('feedback');
        const feedbackMessage = document.getElementById('feedbackMessage');
        const scoreDisplay = document.getElementById('scoreDisplay');
        const progressBar = document.getElementById('progressBar');
        const questionCounter = document.getElementById('questionCounter');

        let currentQuestionId = parseInt(container.dataset.questionid);
        let answered = false;
        let startTime = Date.now();

        // Делегирование событий для кнопок
        optionsContainer.addEventListener('click', function (e) {
            const button = e.target.closest('.option-btn');
            if (button && !answered) {
                checkAnswer(button);
            }
        });

        function checkAnswer(selectedButton) {
            answered = true;
            const answerTime = Math.floor((Date.now() - startTime) / 1000);
            const isCorrect = selectedButton.dataset.isCorrect === 'true';

            // Блокируем все кнопки
            document.querySelectorAll('.option-btn').forEach(btn => {
                btn.disabled = true;
            });

            // Подсветка
            if (isCorrect) {
                selectedButton.classList.add('btn-success');
                selectedButton.classList.remove('btn-primary');
            } else {
                selectedButton.classList.add('btn-danger');
                selectedButton.classList.remove('btn-primary');

                // Подсвечиваем правильный ответ
                document.querySelectorAll('.option-btn').forEach(btn => {
                    if (btn.dataset.isCorrect === 'true') {
                        btn.classList.add('btn-success');
                        btn.classList.remove('btn-primary');
                    }
                });
            }

            // Показываем результат
            feedback.style.display = 'block';
            feedback.className = isCorrect ? 'alert alert-success text-center mt-4' : 'alert alert-danger text-center mt-4';
            feedbackMessage.innerHTML = isCorrect ? '🎉 Правильно!' : '😕 Неправильно!';

            // Отправляем результат
            fetch('/Game/CheckAnswer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    questionId: currentQuestionId,
                    isCorrect: isCorrect,
                    answerTime: answerTime
                })
            })
                .then(response => response.json())
                .then(data => {
                    console.log('Ответ сервера:', data);

                    if (data.success) {
                        // Обновляем счёт и прогресс
                        if (data.score !== undefined) {
                            scoreDisplay.innerHTML = '⭐ ' + data.score;
                        }
                        if (data.currentIndex !== undefined && data.totalQuestions !== undefined) {
                            progressBar.style.width = (data.currentIndex * 100 / data.totalQuestions) + '%';
                            questionCounter.textContent = (data.currentIndex + 1) + '/' + data.totalQuestions;
                        }

                        if (data.hasNext) {
                            // Обновляем вопрос
                            updateQuestion(data.question);
                        } else {
                            // Игра закончена
                            setTimeout(() => window.location.href = data.redirect, 2000);
                        }
                    }
                })
                .catch(error => {
                    console.error('Ошибка:', error);
                    setTimeout(() => location.reload(), 2000);
                });
        }

        function updateQuestion(question) {
            // Обновляем текст вопроса
            questionText.textContent = question.text;
            currentQuestionId = question.id;

            // Создаём новые кнопки вариантов
            optionsContainer.innerHTML = '';
            question.options.forEach((opt, index) => {
                const col = document.createElement('div');
                col.className = 'col-md-6 mb-3';

                const button = document.createElement('button');
                button.className = 'option-btn btn btn-primary btn-lg w-100';
                button.dataset.optionId = opt.id;
                button.dataset.isCorrect = opt.isCorrect.toString().toLowerCase();

                button.innerHTML = `
                        <span class="option-letter">${String.fromCharCode(65 + index)}</span>
                        <span class="option-text">${opt.text}</span>
                    `;

                col.appendChild(button);
                optionsContainer.appendChild(col);
            });

            // Сброс UI
            feedback.style.display = 'none';
            document.querySelectorAll('.option-btn').forEach(btn => btn.disabled = false);
            answered = false;
            startTime = Date.now();

            // Прокрутка вверх
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
}

<style>
    .option-btn {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding: 1rem;
        font-size: 1.5rem;
        transition: all 0.3s ease;
    }

    .option-letter {
        background: rgba(255,255,255,0.2);
        border-radius: 50%;
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 15px;
        font-weight: bold;
    }

    .option-btn:active {
        transform: scale(0.95);
    }
</style>