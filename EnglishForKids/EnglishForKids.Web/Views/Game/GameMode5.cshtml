@model EnglishForKids.Web.ViewModels.GameViewModel
@{
    ViewData["Title"] = "Составь предложение";
}

<div class="container mt-3">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2>@Model.TopicTitle</h2>
                <div>
                    <span class="badge bg-warning fs-4" id="scoreDisplay">⭐ @Model.Score</span>
                    <span class="badge bg-info fs-4" id="questionCounter">@(Model.CurrentQuestionIndex+1)/@Model.TotalQuestions</span>
                </div>
            </div>

            <div class="progress mb-4">
                <div class="progress-bar" id="progressBar" style="width: @((Model.CurrentQuestionIndex) * 100.0 / Model.TotalQuestions)%"></div>
            </div>
        </div>
    </div>

    <div id="game-container" data-questionid="@Model.CurrentQuestion.Id" data-total="@Model.TotalQuestions">
        <div class="question-area text-center">
            <h3 class="mb-4">📝 Составь предложение из слов:</h3>

            <!-- Область для составления предложения -->
            <div class="sentence-builder-area p-4 bg-light rounded mb-4" id="buildArea">
                <div class="d-flex flex-wrap gap-2 min-height-100" id="sentenceContainer">
                    <!-- Сюда будут добавляться выбранные слова -->
                </div>
            </div>

            <!-- Доступные слова (перемешанные) -->
            <div class="words-pool p-4 bg-white rounded mb-4" id="wordsPool">
                <h4 class="mb-3">📦 Выбери слова по порядку:</h4>
                <div class="d-flex flex-wrap gap-2 justify-content-center" id="availableWords">
                    @if (Model.CurrentQuestion.SentenceParts != null)
                    {
                        var shuffled = Model.CurrentQuestion.SentenceParts
                            .Where(s => !s.IsPunctuation)
                            .OrderBy(s => Guid.NewGuid())
                            .ToList();

                        foreach (var part in shuffled)
                        {
                            <button class="word-card btn btn-primary btn-lg"
                                    data-word-id="@part.Id"
                                    data-word-text="@part.WordText"
                                    data-word-order="@part.WordOrder">
                                @part.WordText
                            </button>
                        }
                    }
                </div>
            </div>

            <!-- Кнопки управления -->
            <div class="d-flex justify-content-center gap-3 mt-4">
                <button id="checkBtn" class="btn btn-success btn-lg" disabled>✅ Проверить</button>
                <button id="resetBtn" class="btn btn-warning btn-lg">🔄 Начать заново</button>
                <button id="clearBtn" class="btn btn-secondary btn-lg">🗑 Очистить</button>
            </div>

            <!-- Подсказка для младших классов -->
            <div class="simplified-options mt-4 p-3 bg-info bg-opacity-10 rounded">
                <h4>👶 Для маленьких (выбери готовый вариант):</h4>
                <div class="d-flex gap-2 justify-content-center flex-wrap" id="simplifiedOptions">
                    @{
                        var correctOrder = Model.CurrentQuestion.SentenceParts
                            .Where(s => !s.IsPunctuation)
                            .OrderBy(s => s.WordOrder)
                            .Select(s => s.WordText)
                            .ToList();

                        var options = new List<List<string>>();
                        options.Add(correctOrder);

                        // Генерируем 2 неправильных варианта
                        var random = new Random();
                        for (int i = 0; i < 2; i++)
                        {
                            var wrong = correctOrder.OrderBy(x => random.Next()).ToList();
                            options.Add(wrong);
                        }

                        options = options.OrderBy(x => random.Next()).ToList();
                    }

                    @foreach (var option in options)
                    {
                        <button class="simplified-option btn btn-outline-primary btn-lg"
                                data-option='@System.Text.Json.JsonSerializer.Serialize(option)'>
                            @string.Join(" ", option)
                        </button>
                    }
                </div>
            </div>
        </div>

        <div id="feedback" class="text-center mt-4" style="display: none;">
            <h2 id="feedbackMessage"></h2>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Элементы
        const container = document.getElementById('game-container');
        const buildArea = document.getElementById('sentenceContainer');
        const availableWords = document.getElementById('availableWords');
        const checkBtn = document.getElementById('checkBtn');
        const resetBtn = document.getElementById('resetBtn');
        const clearBtn = document.getElementById('clearBtn');
        const simplifiedOptions = document.getElementById('simplifiedOptions');
        const feedback = document.getElementById('feedback');
        const feedbackMessage = document.getElementById('feedbackMessage');
        const scoreDisplay = document.getElementById('scoreDisplay');
        const progressBar = document.getElementById('progressBar');
        const questionCounter = document.getElementById('questionCounter');

        let currentQuestionId = parseInt(container.dataset.questionid);
        let totalQuestions = parseInt(container.dataset.total);
        let sentenceParts = [];
        let correctOrder = [];
        let answered = false;
        let startTime = Date.now();

        console.log('========== РЕЖИМ 5 ЗАГРУЖЕН ==========');
        console.log('ID вопроса:', currentQuestionId);
        console.log('Всего вопросов:', totalQuestions);

        // Инициализация - собираем все части предложения
        function initGame() {
            console.log('Инициализация игры...');

            // Собираем все слова с их порядком
            document.querySelectorAll('[data-word-order]').forEach(btn => {
                sentenceParts.push({
                    id: parseInt(btn.dataset.wordId),
                    text: btn.dataset.wordText,
                    order: parseInt(btn.dataset.wordOrder)
                });
            });

            // Сохраняем правильный порядок
            correctOrder = sentenceParts
                .sort((a, b) => a.order - b.order)
                .map(p => p.text);

            console.log('Правильный порядок:', correctOrder);
            console.log('Найдено частей предложения:', sentenceParts.length);

            // Перемешиваем слова для отображения
            shuffleWords();

            checkBtn.disabled = true;
        }

        // Перемешивание слов
        function shuffleWords() {
            const words = Array.from(availableWords.children);
            const shuffled = words.sort(() => Math.random() - 0.5);
            availableWords.innerHTML = '';
            shuffled.forEach(word => availableWords.appendChild(word));
            console.log('Слова перемешаны');
        }

        // Обработчик клика по доступным словам
        availableWords.addEventListener('click', function (e) {
            const wordBtn = e.target.closest('.word-card');
            if (!wordBtn || answered) return;

            const wordId = wordBtn.dataset.wordId;
            const wordText = wordBtn.dataset.wordText;

            console.log('Выбрано слово:', wordText);

            // Создаем элемент в области сборки
            const wordElement = document.createElement('button');
            wordElement.className = 'word-card btn btn-success btn-lg';
            wordElement.dataset.wordId = wordId;
            wordElement.dataset.wordText = wordText;
            wordElement.textContent = wordText;

            // Добавляем обработчик для удаления
            wordElement.addEventListener('click', function (e) {
                e.stopPropagation();
                if (answered) return;
                removeWord(wordElement);
            });

            buildArea.appendChild(wordElement);

            // Удаляем из доступных
            wordBtn.remove();

            // Активируем кнопку проверки
            checkBtn.disabled = buildArea.children.length === 0;
            console.log('Слов добавлено. Всего в предложении:', buildArea.children.length);
        });

        // Удаление слова из предложения
        function removeWord(wordElement) {
            if (answered) return;

            const wordId = wordElement.dataset.wordId;
            const wordText = wordElement.dataset.wordText;

            console.log('Удалено слово:', wordText);

            // Возвращаем слово в доступные
            const newWordBtn = document.createElement('button');
            newWordBtn.className = 'word-card btn btn-primary btn-lg';
            newWordBtn.dataset.wordId = wordId;
            newWordBtn.dataset.wordText = wordText;
            newWordBtn.dataset.wordOrder = sentenceParts.find(p => p.id == wordId)?.order || 0;
            newWordBtn.textContent = wordText;

            availableWords.appendChild(newWordBtn);

            // Удаляем из предложения
            wordElement.remove();

            // Обновляем состояние кнопки проверки
            checkBtn.disabled = buildArea.children.length === 0;
        }

        // Сброс всего
        resetBtn.addEventListener('click', function () {
            if (answered) return;

            console.log('Сброс игры');

            // Очищаем предложение
            buildArea.innerHTML = '';

            // Восстанавливаем все слова
            availableWords.innerHTML = '';
            sentenceParts.forEach(part => {
                const wordBtn = document.createElement('button');
                wordBtn.className = 'word-card btn btn-primary btn-lg';
                wordBtn.dataset.wordId = part.id;
                wordBtn.dataset.wordText = part.text;
                wordBtn.dataset.wordOrder = part.order;
                wordBtn.textContent = part.text;
                availableWords.appendChild(wordBtn);
            });

            shuffleWords();
            checkBtn.disabled = true;
        });

        // Очистка предложения
        clearBtn.addEventListener('click', function () {
            if (answered) return;

            console.log('Очистка предложения');

            // Возвращаем все слова обратно
            while (buildArea.firstChild) {
                const word = buildArea.firstChild;
                removeWord(word);
            }
        });

        // Упрощенные варианты для младших классов
        simplifiedOptions.addEventListener('click', function (e) {
            const optionBtn = e.target.closest('.simplified-option');
            if (!optionBtn || answered) return;

            const optionText = optionBtn.textContent.trim();
            const words = optionText.split(' ');

            console.log('Выбран упрощенный вариант:', words);

            // Очищаем текущее предложение
            buildArea.innerHTML = '';

            // Удаляем все слова из доступных
            availableWords.innerHTML = '';

            // Добавляем слова из выбранного варианта в правильном порядке
            words.forEach(wordText => {
                const part = sentenceParts.find(p => p.text === wordText);
                if (part) {
                    const wordElement = document.createElement('button');
                    wordElement.className = 'word-card btn btn-success btn-lg';
                    wordElement.dataset.wordId = part.id;
                    wordElement.dataset.wordText = part.text;
                    wordElement.textContent = part.text;

                    wordElement.addEventListener('click', function (e) {
                        e.stopPropagation();
                        if (answered) return;
                        removeWord(wordElement);
                    });

                    buildArea.appendChild(wordElement);
                }
            });

            checkBtn.disabled = false;
        });

        // Проверка ответа
        checkBtn.addEventListener('click', function () {
            if (answered || buildArea.children.length === 0) return;

            answered = true;
            const answerTime = Math.floor((Date.now() - startTime) / 1000);

            // Получаем порядок слов в предложении
            const userOrder = Array.from(buildArea.children).map(btn => btn.dataset.wordText);
            const isCorrect = JSON.stringify(userOrder) === JSON.stringify(correctOrder);

            console.log('========== РЕЗУЛЬТАТ ==========');
            console.log('Порядок пользователя:', userOrder);
            console.log('Правильный порядок:', correctOrder);
            console.log('Результат:', isCorrect ? 'ПРАВИЛЬНО' : 'НЕПРАВИЛЬНО');

            // Блокируем все интерактивные элементы
            document.querySelectorAll('button').forEach(btn => btn.disabled = true);

            // Показываем результат
            feedback.style.display = 'block';
            feedback.className = isCorrect ? 'alert alert-success text-center mt-4' : 'alert alert-danger text-center mt-4';

            if (isCorrect) {
                feedbackMessage.innerHTML = '🎉 Правильно! Отличное предложение!';
            } else {
                const correctSentence = correctOrder.join(' ');
                feedbackMessage.innerHTML = `😕 Неправильно!<br><small>Правильно: ${correctSentence}</small>`;
            }

            console.log('Отправка ответа на сервер...');

            // Отправляем результат на сервер
            fetch('/Game/CheckAnswer', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    questionId: currentQuestionId,
                    isCorrect: isCorrect,
                    answerTime: answerTime
                })
            })
                .then(response => {
                    console.log('Статус ответа:', response.status);
                    return response.json();
                })
                .then(data => {
                    console.log('Данные от сервера:', data);

                    if (data.success) {
                        // Обновляем счет и прогресс
                        if (data.score !== undefined) {
                            scoreDisplay.innerHTML = '⭐ ' + data.score;
                            console.log('Счет обновлен:', data.score);
                        }

                        if (data.currentIndex !== undefined && data.totalQuestions !== undefined) {
                            const progress = (data.currentIndex * 100 / data.totalQuestions);
                            progressBar.style.width = progress + '%';
                            questionCounter.textContent = (data.currentIndex + 1) + '/' + data.totalQuestions;
                            console.log('Прогресс обновлен:', data.currentIndex + 1, '/', data.totalQuestions);
                        }

                        if (data.hasNext) {
                            console.log('Есть следующий вопрос. Загружаем через 3 секунды...');
                            setTimeout(() => {
                                updateQuestion(data.question);
                            }, 3000);
                        } else {
                            console.log('Игра закончена. Редирект на результаты...');
                            setTimeout(() => {
                                window.location.href = data.redirect;
                            }, 3000);
                        }
                    } else {
                        console.error('Ошибка от сервера:', data.error);
                        setTimeout(() => location.reload(), 3000);
                    }
                })
                .catch(error => {
                    console.error('Ошибка при отправке:', error);
                    setTimeout(() => location.reload(), 3000);
                });
        });

        // Функция обновления вопроса
        function updateQuestion(question) {
            console.log('========== ОБНОВЛЕНИЕ ВОПРОСА ==========');
            console.log('Новый вопрос:', question);

            // Обновляем ID вопроса
            currentQuestionId = question.id;

            // Очищаем все контейнеры
            buildArea.innerHTML = '';
            availableWords.innerHTML = '';
            sentenceParts = [];

            // Создаем новые кнопки для слов
            question.sentenceParts.forEach(part => {
                if (!part.isPunctuation) {
                    sentenceParts.push({
                        id: part.id,
                        text: part.wordText,
                        order: part.wordOrder
                    });

                    const wordBtn = document.createElement('button');
                    wordBtn.className = 'word-card btn btn-primary btn-lg';
                    wordBtn.dataset.wordId = part.id;
                    wordBtn.dataset.wordText = part.wordText;
                    wordBtn.dataset.wordOrder = part.wordOrder;
                    wordBtn.textContent = part.wordText;
                    availableWords.appendChild(wordBtn);
                }
            });

            // Обновляем правильный порядок
            correctOrder = sentenceParts
                .sort((a, b) => a.order - b.order)
                .map(p => p.text);

            console.log('Новый правильный порядок:', correctOrder);

            // Перемешиваем слова
            shuffleWords();

            // Обновляем упрощенные варианты
            updateSimplifiedOptions(question);

            // Сбрасываем состояния
            feedback.style.display = 'none';
            answered = false;
            startTime = Date.now();
            checkBtn.disabled = true;

            console.log('Готов к следующему вопросу!');
        }

        // Функция обновления упрощенных вариантов
        function updateSimplifiedOptions(question) {
            const optionsContainer = document.getElementById('simplifiedOptions');
            optionsContainer.innerHTML = '';

            // Получаем правильный порядок слов
            const correctWords = question.sentenceParts
                .filter(p => !p.isPunctuation)
                .sort((a, b) => a.wordOrder - b.wordOrder)
                .map(p => p.wordText);

            // Создаем варианты
            const options = [];
            options.push(correctWords);

            // Генерируем 2 неправильных варианта
            for (let i = 0; i < 2; i++) {
                const wrong = [...correctWords].sort(() => Math.random() - 0.5);
                options.push(wrong);
            }

            // Перемешиваем варианты
            options.sort(() => Math.random() - 0.5);

            // Отображаем варианты
            options.forEach(option => {
                const btn = document.createElement('button');
                btn.className = 'simplified-option btn btn-outline-primary btn-lg';
                btn.dataset.option = JSON.stringify(option);
                btn.textContent = option.join(' ');
                optionsContainer.appendChild(btn);
            });
        }

        // Запускаем инициализацию
        initGame();
    </script>
}

<style>
    .sentence-builder-area {
        min-height: 120px;
        border: 3px dashed #3498db;
        border-radius: 20px;
        background-color: #f8f9fa;
    }

    .min-height-100 {
        min-height: 100px;
    }

    .word-card {
        font-size: 1.5rem;
        padding: 1rem 2rem;
        border-radius: 50px;
        margin: 5px;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        cursor: pointer;
    }

        .word-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        .word-card:active {
            transform: scale(0.95);
        }

        .word-card:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .words-pool {
        background-color: white;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .simplified-option {
        font-size: 1.3rem;
        padding: 1rem 2rem;
        border-radius: 50px;
        transition: all 0.3s ease;
        margin: 5px;
    }

        .simplified-option:hover {
            background-color: #3498db;
            color: white;
        }

    .btn-success {
        background: linear-gradient(135deg, #27ae60, #229954);
        border: none;
    }

    .btn-primary {
        background: linear-gradient(135deg, #3498db, #2980b9);
        border: none;
    }

    .btn-warning {
        background: linear-gradient(135deg, #f39c12, #e67e22);
        border: none;
        color: white;
    }

    .btn-secondary {
        background: linear-gradient(135deg, #95a5a6, #7f8c8d);
        border: none;
    }

    .alert {
        font-size: 1.5rem;
        padding: 1.5rem;
        border-radius: 50px;
    }
</style>