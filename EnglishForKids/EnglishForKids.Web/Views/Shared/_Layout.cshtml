@using Microsoft.AspNetCore.Http
@using EnglishForKids.Data.Entities.Identity
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EnglishForKids</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/kids-theme.css" />
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;700&family=Nunito:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
    <header class="mascot-header">
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <img src="/images/logo/logo.png" alt="EnglishForKids" height="50">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/">🏠 Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Topic">📚 Темы</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Game/Index">🎮 Игры</a>
                        </li>

                        @{
                            var childId = Context.Session.GetInt32("ChildId");
                        }

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/ParentDashboard">👨‍👩‍👧 Мой кабинет</a>
                            </li>
                            <li class="nav-item">
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link" style="border: none; background: none; cursor: pointer;">
                                        Выйти
                                    </button>
                                </form>
                            </li>
                        }
                        else if (childId.HasValue)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/ChildDashboard">👶 @Context.Session.GetString("ChildName")</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Pet">🐶 Питомец</a>  <!-- Добавлено -->
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("ChildLogout", "Account")">👋 Выйти</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Login">👨‍👩‍👧 Родитель</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/ChildLogin">👶 Ребенок</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-5">
        @RenderBody()
    </main>

    <!-- Маскот -->
    <div class="mascot-fixed" id="mascot">
        <div class="mascot-speech" id="mascotSpeech">
            Привет! Я помогу тебе учить английский! 👋
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/vue@2.7.14/dist/vue.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>