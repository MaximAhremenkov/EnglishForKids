@model EnglishForKids.Data.Entities.Topic

@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-4">@Model.Title</h1>
            <p class="text-center lead mb-5">@Model.Description</p>
        </div>
    </div>

    @if (Model.Rules != null && Model.Rules.Any())
    {
        <div class="row mb-5">
            <div class="col-12">
                <h2 class="mb-4">📖 Правила</h2>
                @foreach (var rule in Model.Rules)
                {
                    <div class="question-area mb-4">
                        <h3>@rule.Title</h3>
                        <div class="rule-content p-3">
                            <p>@Html.Raw(rule.TheoryText)</p>
                            <div class="example bg-light p-3 rounded">
                                <strong>Пример:</strong> @rule.ExampleText
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row">
        <div class="col-12 text-center">
            <h2 class="mb-4">🎮 Выбери режим игры</h2>

            <a href="/Game/SelectMode?topicId=@Model.Id" class="btn btn-primary btn-lg">
                Выбрать режим игры
            </a>
        </div>
    </div>
</div>